# traefik-viewer secrets — example. Copy to .env and fill in as needed.
#   cp .env.example .env
#
# .env is gitignored. Values here are referenced from config.yaml via ${VAR}.
# Per-instance /api credentials are OPTIONAL — if your downstream /api is open
# (no auth), leave them blank. The config's ${VAR:-} defaults mean an empty
# value simply sends no auth header. Fill them in when /api is behind basicAuth.
#
# The variable names must match the ${...} references in your config. The names
# below correspond to the instances in config.example.yaml (gateway, node-01,
# node-02); rename to match your own config.

# --- gateway ---
GATEWAY_API_USER=admin
GATEWAY_API_PASS=

# --- node-01 ---
NODE01_API_USER=admin
NODE01_API_PASS=

# --- node-02 ---
NODE02_API_USER=admin
NODE02_API_PASS=

# --- Loki (optional; only if loki.url is set) ---
LOKI_USER=
LOKI_PASS=
